% EndEvent_1 must eventually occur after Task_FFW_Send.
% Once the source occurs, translator-internal steps may delay the response,
% but every reachable pre-response state must keep the target reachable.
[true* . (exists oid: OrderId. c_send_request(oid))]
nu X. (<true* . (exists oid: OrderId. endevent_1(oid))>true && [!(exists oid: OrderId. endevent_1(oid))]X)